# Environment
ENVIRONMENT=dev
DEBUG=true
LOG_LEVEL=INFO

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mlops
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
TIMESCALEDB_ENABLED=true

# Storage
S3_ENDPOINT=https://s3.amazonaws.com
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET=mlops-data
S3_REGION=us-east-1
USE_MINIO=false
MINIO_ENDPOINT=http://localhost:9000

# Feature Store
FEAST_REGISTRY_PATH=feature_store/registry.db
FEAST_ONLINE_STORE_TYPE=redis
FEAST_OFFLINE_STORE_TYPE=file
DORIS_HOST=localhost
DORIS_PORT=9030
DORIS_USER=root
DORIS_PASSWORD=
DORIS_DATABASE=feast

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_REGISTRY_URI=sqlite:///mlruns.db
MLFLOW_EXPERIMENT_NAME=default
MLFLOW_ARTIFACT_LOCATION=s3://mlops-artifacts

# Ray
RAY_ADDRESS=auto
RAY_NUM_CPUS=4
RAY_NUM_GPUS=0
RAY_OBJECT_STORE_MEMORY=4000000000
RAY_DASHBOARD_HOST=0.0.0.0
RAY_DASHBOARD_PORT=8265

# Monitoring
EVIDENTLY_DASH_PORT=8050
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006
WHYLOGS_WHYLABS_KEY=
WHYLOGS_WHYLABS_ORG_ID=
ALERT_WEBHOOK_URL=
DRIFT_THRESHOLD=0.1
PERFORMANCE_THRESHOLD=0.05

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
CORS_ORIGINS=["*"]

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Redis (for caching and message queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
